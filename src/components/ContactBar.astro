---
---
<section style="background-color: #a75c4a;" class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 text-white">

      <div>
        <div class="flex items-center gap-3 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="text-sm font-bold tracking-widest uppercase">Contact Us</span>
        </div>
        <p class="text-sm text-white/90 mb-1"><a href="tel:9857730449" class="hover:text-white">(985) 773-0449</a></p>
        <p class="text-sm text-white/90 mb-5"><a href="mailto:grace@midwifegrace.com" class="hover:text-white">grace@midwifegrace.com</a></p>
        <a href="/contact" class="text-[11px] font-semibold tracking-widest uppercase border border-white/60 px-4 py-2 hover:bg-white/10 transition-colors inline-block">
          Schedule a Consultation
        </a>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-sm font-bold tracking-widest uppercase">Locations</span>
        </div>
        <ul class="space-y-3 text-sm text-white/90">
          <li>340 Brakefield Street<br />Slidell, LA 70458</li>
          <li>407 Main Street<br />Madisonville, LA 70447</li>
          <li>223 N. Rendon<br />New Orleans, LA 70119</li>
        </ul>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm font-bold tracking-widest uppercase">Hours</span>
        </div>
        <ul class="space-y-1 text-sm text-white/90">
          {['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'].map(day => (
            <li class="flex justify-between gap-4"><span>{day}</span><span>9:00 AM – 5:00 PM</span></li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
