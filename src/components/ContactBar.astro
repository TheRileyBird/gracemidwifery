---
---
<section style="background: linear-gradient(to bottom, #fff 50%, #a75c4a 50%);" class="py-16">
  <div class="max-w-lg lg:max-w-5xl mx-auto px-6">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="grid lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-gray-100 p-8">

        <!-- Contact Us -->
        <div class="px-10 py-5 text-center lg:text-left">
          <div class="flex flex-col items-center justify-center gap-3 mb-6 lg:flex-row lg:justify-start">
            <div class="w-10 h-10 rounded-lg bg-brand-primary flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold tracking-widest uppercase" style="color: #121111;">Contact Us</h3>
          </div>
          <p class="text-sm mb-3"><a href="tel:9857730449" class="hover:underline">(985) 773-0449</a></p>
          <p class="text-sm mb-6"><a href="mailto:grace@midwifegrace.com" class="hover:underline">grace@midwifegrace.com</a></p>
          <a href="/contact" class="font-bold text-sm" style="color: #121111;">Schedule A Consultation</a>
        </div>

        <!-- Locations -->
        <div class="px-10 py-5 text-center lg:text-left">
          <div class="flex flex-col items-center justify-center gap-3 mb-6 lg:flex-row lg:justify-start">
            <div class="w-10 h-10 rounded-lg bg-brand-primary flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold tracking-widest uppercase" style="color: #121111;">Locations</h3>
          </div>
          <ul class="space-y-4 text-sm">
            <li>340 Brakefield Street<br />Slidell, LA 70458</li>
            <li>407 Main Street<br />Madisonville, LA 70447</li>
            <li>223 N. Rendon,<br />New Orleans 70119</li>
          </ul>
        </div>

        <!-- Hours -->
        <div class="px-10 py-5 text-center lg:text-left">
          <div class="flex flex-col items-center justify-center gap-3 mb-6 lg:flex-row lg:justify-start">
            <div class="w-10 h-10 rounded-lg bg-brand-primary flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold tracking-widest uppercase" style="color: #121111;">Hours</h3>
          </div>
          <ul class="space-y-2 text-sm">
            {['Monday', 'Tuesday', 'Wed', 'Thurs', 'Friday'].map(day => (
              <li class="flex justify-between gap-8">
                <span>{day}:</span>
                <span>9:00 AM – 5:00 PM</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>
