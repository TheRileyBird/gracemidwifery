---
import { Image } from 'astro:assets';
import { X } from '@lucide/astro';

import flyerPortrait from '../assets/images/flyer.png';
import flyerLandscape from '../assets/images/flyer-horizontal.png';
---

<div
  x-data="{
    isPopupEnabled: false,
    isOpen: false,
    storageKey: 'grace-midwifery-flyer-dismissed-at',
    weekInMs: 7 * 24 * 60 * 60 * 1000,
    init() {
      try {
        const dismissedAt = Number(window.localStorage.getItem(this.storageKey) || 0);
        this.isOpen = !dismissedAt || Date.now() - dismissedAt > this.weekInMs;
      } catch {
        this.isOpen = true;
      }
    },
    close() {
      this.isOpen = false;

      try {
        window.localStorage.setItem(this.storageKey, String(Date.now()));
      } catch {}
    },
  }"
  x-show="isPopupEnabled && isOpen"
  x-cloak
  x-transition.opacity.duration.200ms
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 px-4 py-6 sm:px-6"
  role="presentation"
  @click="close()"
  @keydown.escape.window="close()"
>
  <div
    class="relative flex max-h-full w-full max-w-[min(92vw,28rem)] flex-col items-center gap-4 rounded-xl p-4 md:max-w-[min(88vw,58rem)] md:p-5"
    style="background-color: #091713;"
    role="dialog"
    aria-modal="true"
    aria-label="Grace Midwifery Collective flyer"
    @click.stop
  >
    <button
      type="button"
      class="absolute right-2 top-2 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/95 text-brand-primary shadow-lg transition hover:bg-white focus:outline-hidden focus:ring-2 focus:ring-brand-primary focus:ring-offset-2"
      aria-label="Close flyer"
      @click="close()"
    >
      <X class="h-5 w-5" aria-hidden="true" />
    </button>

    <a
      href="/contact"
      class="block w-full"
      aria-label="Contact Grace Midwifery Collective"
      @click="close()"
    >
      <Image
        src={flyerPortrait}
        alt="Grace Midwifery Collective flyer"
        width={1054}
        height={1492}
        class="block max-h-[80vh] w-full rounded-lg object-contain shadow-2xl md:hidden"
        loading="eager"
      />
      <Image
        src={flyerLandscape}
        alt="Grace Midwifery Collective flyer"
        width={1491}
        height={1055}
        class="hidden max-h-[78vh] w-full rounded-lg object-contain shadow-2xl md:block"
        loading="eager"
      />
    </a>

    <a
      href="/contact"
      class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-primary px-8 py-3 text-base font-semibold text-white shadow-lg transition hover:bg-accent-dark focus:outline-hidden focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-brand-primary"
      @click="close()"
    >
      Reserve My Spot!
    </a>
  </div>
</div>
