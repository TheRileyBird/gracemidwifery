---

<!-- Dark footer -->
<footer class="relative overflow-hidden bg-brand-primary">

  <ContactBar />
  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 py-14 text-center">
    <!-- Full text logo -->
    <Image
      src={logo}
      alt="Grace Midwifery Collective"
      class="mx-auto mb-8 w-96"
      style="filter: brightness(0) invert(1); opacity: 0.9;"
    />

    <!-- Nav links -->
    <nav class="flex flex-wrap justify-center gap-5 mb-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="text-base font-semibold tracking-widest text-white/60 hover:text-white transition-colors"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Social icons -->
    <div class="flex justify-center gap-3">
      {socials.map(({ label, href, svg }) => (
        <a
          href={href}
          aria-label={label}
          class="w-9 h-9 rounded-full border border-white/25 flex items-center justify-center text-white/60 hover:text-white hover:border-white/50 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" set:html={svg} />
        </a>
      ))}
    </div>
  </div>
</footer>
