---
import { Image } from 'astro:assets';
import icon from '../assets/images/logo-only.png';
import logo from '../assets/images/text-large.png';

const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/midwifery-care', label: 'MIDWIFERY CARE' },
  {
    href: '/birth-doula',
    label: 'DOULA',
    children: [
      { href: '/birth-doula', label: 'BIRTH DOULA' },
      { href: '/doula-support', label: 'POSTPARTUM DOULA' },
    ],
  },
  { href: '/education', label: 'EDUCATION' },
  { href: '/faq', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header
  x-data="{ open: false, scrolled: false, doulaOpen: false, mobileDoulaOpen: false }"
  @scroll.window="scrolled = window.scrollY > 24"
  :class="scrolled ? 'h-[60px] shadow-md' : 'h-[88px]'"
  class="bg-white w-full sticky top-0 z-50 transition-all duration-300 ease-in-out h-[88px]"
>
  <nav class="w-full px-8 flex items-center justify-between h-full">
    <!-- Logo -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a href="/">
        <Image
          src={icon}
          alt="Grace Midwifery Collective"
          style="height:56px"
          :style="scrolled ? 'height:36px' : 'height:56px'"
          class="w-auto transition-all duration-300 ease-in-out"
        />
      </a>
      <a href="/">
        <Image
          src={logo}
          alt="Grace Midwifery Collective"
          style="height:28px"
          :style="scrolled ? 'height:20px' : 'height:28px'"
          class="w-auto transition-all duration-300 ease-in-out"
        />
      </a>
    </div>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-7">
      <ul class="flex items-center gap-7">
        {navLinks.map(link => (
          <li class="relative">
            {link.children ? (
              <div
                class="relative"
                @mouseenter="doulaOpen = true"
                @mouseleave="doulaOpen = false"
              >
                <div class="flex items-center gap-2">
                  <a
                    href={link.href}
                    class="font-serif text-sm font-semibold tracking-widest transition-colors duration-200"
                    style={link.children.some(({ href }) => currentPath === href) ? 'color: #a75c4a;' : 'color: #494f5e;'}
                  >
                    {link.label}
                  </a>
                  <button
                    type="button"
                    class="flex items-center font-serif transition-colors duration-200"
                    style={link.children.some(({ href }) => currentPath === href) ? 'color: #a75c4a;' : 'color: #494f5e;'}
                    @click="doulaOpen = !doulaOpen"
                    aria-label="Toggle doula menu"
                  >
                    <svg class="h-3.5 w-3.5 transition-transform duration-200" :class="doulaOpen ? 'rotate-180' : ''" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                </div>
                <div
                  x-show="doulaOpen"
                  x-transition
                  x-cloak
                  class="absolute left-0 top-full min-w-[240px] pt-3"
                >
                  <div class="rounded-2xl border border-gray-100 bg-white p-3 shadow-lg">
                    {link.children.map(({ href, label }) => (
                      <a
                        href={href}
                        class="block rounded-xl px-4 py-3 text-sm font-serif font-semibold tracking-widest transition-colors duration-200 hover:bg-brand-light"
                        style={currentPath === href ? 'color: #a75c4a;' : 'color: #494f5e;'}
                      >
                        {label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class="font-serif font-semibold text-sm tracking-widest transition-colors duration-200"
                style={currentPath === link.href ? 'color: #a75c4a;' : 'color: #494f5e;'}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
      <a
        href="/contact"
        class="font-serif font-semibold text-sm tracking-widest text-white px-5 py-2 rounded-full transition-opacity hover:opacity-90 bg-brand-primary"
      >
        CONTACT
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      @click="open = !open"
      class="lg:hidden p-2 text-contrast-2"
      aria-label="Toggle menu"
    >
      <svg x-show="!open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg x-show="open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" x-cloak>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    x-show="open"
    x-transition
    class="lg:hidden bg-white border-t border-gray-100 px-8 pb-6"
    x-cloak
  >
    <ul class="flex flex-col pt-4">
      {navLinks.map(link => (
        <li class="border-b border-gray-50">
          {link.children ? (
            <div class="py-1">
              {link.children.map(({ href, label }) => (
                <a
                  href={href}
                  class="block py-3 font-serif font-semibold tracking-widest transition-colors"
                  style={currentPath === href ? 'color: #a75c4a;' : 'color: #494f5e;'}
                >
                  {label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={link.href}
              class="block py-3 font-serif font-semibold tracking-widest text-contrast-2 hover:text-accent-dark transition-colors"
            >
              {link.label}
            </a>
          )}
        </li>
      ))}
      <li class="pt-4">
        <a
          href="/contact"
          class="inline-block font-serif font-semibold tracking-widest text-white px-5 py-2 rounded-full bg-brand-primary"
        >
          CONTACT
        </a>
      </li>
    </ul>
  </div>
</header>
