---
import { Image } from 'astro:assets';
import icon from '../assets/images/logo-only.png';
import logo from '../assets/images/text-large.png';

const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/midwifery-care', label: 'MIDWIFERY CARE' },
  { href: '/doula-support', label: 'DOULA SUPPORT' },
  { href: '/education', label: 'EDUCATION' },
  { href: '/faq', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header
  x-data="{ open: false, scrolled: false }"
  @scroll.window="scrolled = window.scrollY > 24"
  :class="scrolled ? 'h-[60px] shadow-md' : 'h-[88px]'"
  class="bg-white w-full sticky top-0 z-50 transition-all duration-300 ease-in-out h-[88px]"
>
  <nav class="w-full px-8 flex items-center justify-between h-full">
    <!-- Logo -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a href="/">
        <Image
          src={icon}
          alt="Grace Midwifery Collective"
          style="height:56px"
          :style="scrolled ? 'height:36px' : 'height:56px'"
          class="w-auto transition-all duration-300 ease-in-out"
        />
      </a>
      <a href="/">
        <Image
          src={logo}
          alt="Grace Midwifery Collective"
          style="height:28px"
          :style="scrolled ? 'height:20px' : 'height:28px'"
          class="w-auto transition-all duration-300 ease-in-out"
        />
      </a>
    </div>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-7">
      <ul class="flex items-center gap-7">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="font-semibold tracking-widest transition-colors duration-200"
              style={currentPath === href ? 'color: #a75c4a;' : 'color: #494f5e;'}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href="/contact"
        class="font-semibold tracking-widest text-white px-5 py-2 rounded-full transition-opacity hover:opacity-90 bg-brand-primary"
      >
        CONTACT
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      @click="open = !open"
      class="lg:hidden p-2 text-contrast-2"
      aria-label="Toggle menu"
    >
      <svg x-show="!open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg x-show="open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" x-cloak>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    x-show="open"
    x-transition
    class="lg:hidden bg-white border-t border-gray-100 px-8 pb-6"
    x-cloak
  >
    <ul class="flex flex-col pt-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block py-3 font-semibold tracking-widest text-contrast-2 hover:text-accent-dark border-b border-gray-50 transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-4">
        <a
          href="/contact"
          class="inline-block font-semibold tracking-widest text-white px-5 py-2 rounded-full bg-brand-primary"
        >
          CONTACT
        </a>
      </li>
    </ul>
  </div>
</header>
