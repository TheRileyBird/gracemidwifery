---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  bg?: string;
  image: ImageMetadata;
  imageAlt?: string;
  imageLeft?: boolean;
  minHeight?: string;
  imagePosition?: string;
  justify?: 'start' | 'center';
}

const {
  bg = 'white',
  image,
  imageAlt = '',
  imageLeft = false,
  minHeight = '420px',
  imagePosition = 'center',
  justify = 'start',
} = Astro.props;

const textColClass = [
  'px-10 lg:px-16 py-32 w-full',
  justify === 'center' ? 'flex flex-col justify-center' : '',
  imageLeft ? 'md:order-last' : '',
].filter(Boolean).join(' ');

const imageColClass = imageLeft ? 'md:order-first' : '';
---

<section class="overflow-hidden" style={`background-color: ${bg};`}>
  <div class="grid md:grid-cols-2">
    <div class={textColClass}>
      <div class="max-w-2xl mx-auto">
        <slot />
      </div>
    </div>
    <div
      class={`relative ${imageColClass}`}
      style={`min-height: ${minHeight};`}
    >
      <Image
        src={image}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        style={`object-position: ${imagePosition};`}
        aria-hidden={imageAlt ? undefined : 'true'}
      />
    </div>
  </div>
</section>
