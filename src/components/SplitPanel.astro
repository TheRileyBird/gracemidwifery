---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  bg?: string;
  image: ImageMetadata;
  imageAlt?: string;
  imageLeft?: boolean;
  minHeight?: string;
  imagePosition?: string;
  justify?: 'start' | 'center';
  sticky?: boolean;
}

const {
  bg = 'white',
  image,
  imageAlt = '',
  imageLeft = false,
  minHeight = '420px',
  imagePosition = 'center',
  justify = 'start',
  sticky = false,
} = Astro.props;

const textColClass = [
  sticky ? 'px-10 lg:px-16 py-20 w-full' : 'px-10 lg:px-16 py-16 lg:py-32 w-full',
  justify === 'center' ? 'flex flex-col justify-center' : '',
  imageLeft ? 'md:order-last' : '',
].filter(Boolean).join(' ');

const imageColClass = [
  imageLeft ? 'md:order-first' : '',
  sticky ? 'hidden md:block md:sticky md:top-0 md:h-screen' : 'relative',
].filter(Boolean).join(' ');
---

<section class={sticky ? 'overflow-visible' : 'overflow-hidden'} style={`background-color: ${bg};`}>
  <div class={`grid md:grid-cols-2 ${sticky ? 'items-start' : ''}`}>
    <div class={textColClass}>
      <div class="max-w-2xl mx-auto">
        <slot />
      </div>
    </div>
    <div class={imageColClass} style={sticky ? '' : `min-height: ${minHeight};`}>
      <Image
        src={image}
        alt={imageAlt}
        class={sticky ? 'w-full h-full object-cover' : 'absolute inset-0 w-full h-full object-cover'}
        style={`object-position: ${imagePosition};`}
        aria-hidden={imageAlt ? undefined : 'true'}
      />
    </div>
  </div>
</section>
