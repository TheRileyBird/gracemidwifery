---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Grace Midwifery Collective',
  description = 'Evidence-based midwifery care for home births in Louisiana and Mississippi. Your birth. Your body. Your choice.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo-only.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-base text-contrast font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @view-transition {
    navigation: auto;
  }

  [x-cloak] { display: none !important; }

  * { font-family: 'Poppins', system-ui, sans-serif; }

  p {
    color: #494F5E;
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.03px;
    line-height: 1.57;
  }

  h6 {
    color: #DCB393;
    font-family: 'Libre Baskerville', serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.06em;
    line-height: 1.13;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    //justify-content: center;
    gap: 0.5rem;
  }
  h6::before,
  h6::after {
    content: '';
    display: block;
    height: 1px;
    width: 2rem;
    flex-shrink: 0;
    background-color: #DCB393;
  }
</style>
