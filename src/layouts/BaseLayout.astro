---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Grace Midwifery Collective',
  description = 'Evidence-based midwifery care for home births in Louisiana and Mississippi. Your birth. Your body. Your choice.',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://gracemidwiferycollective.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const ogImageUrl = new URL('/images/banner-1.png', siteUrl);
const ogImageAlt = 'Grace Midwifery Collective banner';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Grace Midwifery Collective" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="937" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo-only.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface text-contrast font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root) {
    animation: 500ms ease-in both fade-out;
  }
  ::view-transition-new(root) {
    animation: 500ms ease-out both fade-in;
  }
  @keyframes fade-out {
    to { opacity: 0; }
  }
  @keyframes fade-in {
    from { opacity: 0; }
  }

  [x-cloak] { display: none !important; }

  * { font-family: 'Poppins', system-ui, sans-serif; }

  p {
    color: #494F5E;
    font-size: clamp(14px, 0.875rem + ((1vw - 3.2px) * 0.625), 20px);
    font-weight: 400;
    letter-spacing: 0.03px;
    line-height: 1.57;
  }

  h6 {
    color: #DCB393;
    font-family: 'Libre Baskerville', serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.06em;
    line-height: 1.13;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    //justify-content: center;
    gap: 0.5rem;
  }
  h6::before,
  h6::after {
    content: '';
    display: block;
    height: 1px;
    width: 2rem;
    flex-shrink: 0;
    background-color: #DCB393;
  }
</style>
