---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Grace Midwifery Collective',
  description = 'Evidence-based midwifery care for home births in Louisiana and Mississippi. Your birth. Your body. Your choice.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo-only.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-base text-contrast font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  [x-cloak] { display: none !important; }

  * { font-family: 'Poppins', system-ui, sans-serif; }

  p { color: #494F5E; }

  h6 {
    color: #DCB393;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
</style>
