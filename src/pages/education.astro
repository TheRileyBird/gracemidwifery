---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ContactBar from '../components/ContactBar.astro';
import Footer from '../components/Footer.astro';
import SplitPanel from '../components/SplitPanel.astro';
import { Image } from 'astro:assets';

import download1 from '../assets/images/download-1.jpg';
---

<BaseLayout title="Childbirth Education | Grace Midwifery Collective" description="Evidence-based childbirth education classes in Madisonville, LA with Adele Willman BSN RN CCBE.">
  <Nav />

  <SplitPanel image={download1} bg="#E5F2EF" imageAlt="Childbirth Education" minHeight="70vh" justify="center">
    <h6>Childbirth Education</h6>
    <h1 class="text-5xl font-semibold mb-6 leading-tight text-brand-primary">Evidenced Based and Fun</h1>
    <p class="font-semibold mb-6" style="color: #494F5E;">Adele Willman BSN RN CCBE</p>
    <p class="leading-relaxed mb-4">My passion is to empower expectant moms through education. When you know what to anticipate, you can approach birth with confidence, clarity, and calm. Adele brings 15+ years of experience in hospital labor &amp; delivery and community education to every class.</p>
    <p class="leading-relaxed">A mother of four and grandmother of seven, Adele's teaching is grounded in both professional expertise and lived experience. Classes are small, interactive, and genuinely enjoyable.</p>
  </SplitPanel>

  <!-- Syllabus -->
  <section class="py-20 bg-brand-primary">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h6 class="justify-center">Preparing for Birth</h6>
        <h2 class="text-3xl font-semibold text-brand-light">Four 2-Hour Sessions · 6:00–8:00 PM</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {[
          { session: 'Session One',   topics: ['Birth affirmations & the subconscious', 'Expectations vs. reality', 'Birth anatomy & physiology', 'Doula support', 'Nutrition & labor stages'] },
          { session: 'Session Two',   topics: ['Labor coping variations', 'Building your birth plan', 'Medical tests & procedures', 'Labor promotion', 'Prenatal monitoring & fetal positioning'] },
          { session: 'Session Three', topics: ['The labor journey in depth', 'Anatomy & physiology part 2', 'Laboring & pushing positions', 'Immediate postpartum care', 'The placenta'] },
          { session: 'Session Four',  topics: ["Baby's first moments & the golden hour", 'Breastfeeding initiation', 'Newborn care', 'Postpartum healing', 'Non-birthing partner support'] },
        ].map(({ session, topics }) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-semibold mb-4 text-brand-primary">{session}</h3>
            <ul class="space-y-2">
              {topics.map(t => (
                <li class="flex items-start gap-2 text-base leading-relaxed">
                  <span class="flex-shrink-0 font-bold mt-0.5" style="color: #DCB393;">✦</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Online Course + Pricing -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h6>Bonus Inclusion</h6>
          <h2 class="text-3xl font-semibold mb-4 text-brand-primary">Prepared Feeding<br />Online Course</h2>
          <p class="leading-relaxed mb-5">Taught by Amanda Devereux RN, IBCLC, this online course is included with your registration and covers everything you need to feel confident feeding your baby.</p>
          <ul class="space-y-2">
            {['Latch technique', 'Troubleshooting common issues', 'Pumping', 'Bottle introduction', 'Weaning'].map(t => (
              <li class="flex items-start gap-3 text-base leading-relaxed">
                <span class="flex-shrink-0 font-bold mt-0.5 text-brand-primary">✓</span>
                <span>{t}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <h3 class="font-semibold text-lg mb-5" style="color: #121111;">What's Included</h3>
          <ul class="space-y-3 mb-6">
            {['Four 2-hour in-person sessions', 'Two participants included in price', 'Course journal', 'Prepared Feeding online course (Amanda Devereux RN, IBCLC)'].map(item => (
              <li class="flex items-start gap-3 text-base">
                <span class="flex-shrink-0 font-bold mt-0.5 text-brand-primary">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="border-t border-gray-200 pt-5">
            <p class="text-3xl font-semibold text-brand-primary">$250</p>
            <p class="mt-1">per couple / family unit</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="py-20 bg-gradient-to-b from-brand-light to-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h6 class="justify-center">Madisonville, LA</h6>
        <h2 class="text-3xl font-semibold mb-2 text-brand-primary">2026–2027 Class Schedule</h2>
        <p class="">Four Tuesday evenings per session · 6:00 PM – 8:00 PM</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
        {[
          { term: 'April 2026',   dates: ['April 7', 'April 14', 'April 21', 'April 28'] },
          { term: 'July 2026',    dates: ['July 7', 'July 14', 'July 21', 'July 28'] },
          { term: 'October 2026', dates: ['October 6', 'October 13', 'October 20', 'October 27'] },
          { term: 'January 2027', dates: ['January 5', 'January 12', 'January 19', 'January 26'] },
        ].map(({ term, dates }) => (
          <div class="bg-white rounded-xl p-5 shadow-sm text-center">
            <h3 class="font-semibold text-base mb-3 text-brand-primary">{term}</h3>
            <ul class="space-y-1.5 text-base">
              {dates.map(d => <li>{d}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <div class="bg-white rounded-xl p-8 shadow-sm text-center">
        <h3 class="font-semibold text-lg mb-3" style="color: #121111;">Register Now</h3>
        <p class="leading-relaxed mb-5">To register or ask questions, contact Adele directly:</p>
        <a href="tel:9858889355" class="text-2xl font-semibold block mb-2 text-brand-primary">985.888.9355</a>
        <p class="">Text or call Adele Willman BSN RN CCBE</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
