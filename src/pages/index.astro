---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  { quote: 'With her excellence in practice and delightful charm, I would welcome anyone to invite her into your story.', author: 'Rachel E' },
  { quote: 'I am so thankful for the midwives at Grace Midwifery Collective. I love how my son and daughters were included in my prenatal care, and having them at my birth was everything I had hoped for. The midwives answered their questions and made everyone feel safe and comfortable.', author: 'Client' },
  { quote: 'I could never say enough good things about Grace & the practice she has put together. All of the women I come across in her birth studio are all so kind and loving. You can truly tell they all love their work.', author: 'Client' },
  { quote: 'I wish every woman had the opportunity to experience the beauty of home birth with a team of women like Grace Midwifery Collective.', author: 'Client' },
];

const borderColors = ['#DCB393', '#a75c4a', '#E5F2EF', '#FEF2F4'];

const services = [
  { img: '/images/midwifery.jpg',  title: 'Midwifery',             href: '/midwifery-care',  description: 'The Midwifery model of care is built on the understanding that pregnancy and birth are normal life events, not medical emergencies. Care is individualized and centered on informed choice, safety and trust.' },
  { img: '/images/img0223.jpg',    title: 'Lactation',             href: '/midwifery-care',  description: 'Lactation assistance is included in our midwifery package. An International Board Certified Lactation Counselor visits your home at the 3 day visit to assist with a successful start to your breast feeding journey.' },
  { img: '/images/doula.jpeg',     title: 'Doula',                 href: '/doula-support',   description: 'Doulas are an integral part of birth support. We are excited to announce a special opportunity to offer doulas as part of the Grace Midwifery Collective.' },
  { img: '/images/download-1.jpg', title: 'Childbirth Education',  href: '/education',       description: 'Preparing for birth through education is an important part of your parenting journey. Comprehensive and evidence-based classes offered several times per year.' },
  { img: '/images/placenta.jpg',   title: 'Placenta Encapsulation',href: '/contact',         description: 'Placenta encapsulation is a traditional postpartum practice chosen by some families to support recovery after birth. Many parents report benefits such as; improved energy, mood support, and a gentler postpartum transition. For this service text 985-773-0449' },
  { img: '/images/img6328.jpeg',   title: 'Postpartum Care',       href: '/doula-support',   description: 'In-home postpartum care provides quiet, attentive support in the comfort of your home. Scheduled visit check your recovery, weigh and assess your baby, support feeding and offer gentle, holistic guidance. Available for mothers and their newborn regardless of where you birthed.' },
];
---

<BaseLayout
  title="Grace Midwifery Collective | Home Birth Midwifery in Louisiana & Mississippi"
  description="Evidence-based home birth midwifery care in Louisiana and Mississippi. Your birth. Your body. Your choice."
>
  <Nav />

  <!-- ── HERO: image only, 20px side margins, no text ── -->
  <div class="mx-5">
    <img
      src="/images/banner-1.png"
      alt="Grace Midwifery Collective"
      class="w-full block"
      style="max-height: 70vh; object-fit: cover; object-position: center;"
    />
  </div>

  <!-- ── OUR MISSION ── -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h6 class="mb-6">Welcome to Grace Midwifery Collective</h6>
      <h2 class="text-4xl md:text-5xl font-semibold mb-8" style="color: #a75c4a;">
        Our Mission
      </h2>
      <p class="leading-relaxed mb-6">
        We are on a mission to reshape the landscape of maternal health in Louisiana and Mississippi. We believe that when a mother is given <strong class="font-semibold" style="color: #121111;">evidence-based information</strong> and <strong class="font-semibold" style="color: #121111;">the autonomy</strong> to lead her own care, the entire family thrives. At Grace, your appointments aren't rushed—they are opportunities to build a relationship rooted in trust and respect.
      </p>
      <p class="font-semibold italic mb-6" style="color: #a75c4a;">
        Your Birth. Your body. Your choice.
      </p>
      <p class="leading-relaxed">
        Join us in creating a legacy where every mother feels safe, heard, and powerful.
      </p>
    </div>
  </section>

  <!-- ── ABOUT GRACE: #E5F2EF bg, text left, bg-image right ── -->
  <section class="overflow-hidden" style="background-color: #E5F2EF;">
    <div class="grid md:grid-cols-2">
      <!-- Text LEFT on teal bg -->
      <div class="px-10 lg:px-16 py-20">
        <h6 class="mb-5">about me and my vision</h6>
        <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-8" style="color: #a75c4a;">
          Grace Jackson<br />CPM, LM
        </h2>
        <p class="leading-relaxed mb-5">
          Grace Jackson is a Certified Professional Midwife licensed in the state of Louisiana, with over seven years of experience attending home births. Grace provides compassionate, evidence informed midwifery care centered on safety, autonomy and connection.
        </p>
        <p class="leading-relaxed">
          As the founder of Grace Midwifery Collective, Grace is dedicated to igniting a revolution in birth care. The collective brings together a vibrant community of midwives, doulas, childbirth educators, lactation consultants and placenta encapsulation all under one umbrella to offer holistic, respectful and vetted care for every stage of women's health with ease.
        </p>
      </div>
      <!-- Background image RIGHT, full height of section -->
      <div
        style="background-image: url('/images/homebirth-team.jpeg'); background-size: cover; background-position: center top; min-height: 420px;"
        aria-hidden="true"
      ></div>
    </div>
  </section>

  <!-- ── SERVING YOUR COMMUNITY + MAP + TESTIMONIALS ── -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6" style="color: #a75c4a;">
        Serving Your Community
      </h2>
      <p class="leading-relaxed max-w-2xl mx-auto mb-12">
        Midwife Grace serves many communities within southeast Louisiana and southwest Mississippi. We offer home birth within a <strong class="font-semibold" style="color: #121111;">1hr and 10 min radius</strong> of Madisonville. Offering prenatal care conveniently located to your home, with offices in Madisonville, Slidell and New Orleans.
      </p>

      <!-- Map -->
      <div class="w-full mb-14 rounded-lg overflow-hidden bg-gray-100" style="height: 300px;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110305.22!2d-90.15!3d30.42!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8620b34f!2sMadisonville%2C+LA!5e0!3m2!1sen!2sus!4v1234567890"
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Grace Midwifery service area"
        ></iframe>
      </div>

      <!-- Testimonial slider -->
      <div
        x-data={`{ current: 0, total: ${testimonials.length} }`}
        class="relative max-w-2xl mx-auto px-10"
      >
        {testimonials.map((t, i) => (
          <div
            x-show={`current === ${i}`}
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200 absolute inset-0"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="min-h-[80px]"
          >
            <p class="leading-relaxed italic mb-4">
              "{t.quote}"
            </p>
            <p class="text-sm font-semibold" style="color: #494F5E;">— {t.author}</p>
          </div>
        ))}

        <button
          @click="current = current === 0 ? total - 1 : current - 1"
          class="absolute left-0 top-4 text-3xl font-light transition-colors"
          style="color: #c4bdbd;"
          aria-label="Previous"
        >‹</button>
        <button
          @click="current = current === total - 1 ? 0 : current + 1"
          class="absolute right-0 top-4 text-3xl font-light transition-colors"
          style="color: #c4bdbd;"
          aria-label="Next"
        >›</button>

        <div class="flex justify-center gap-2 mt-8">
          {testimonials.map((_, i) => (
            <button
              @click={`current = ${i}`}
              :class={`current === ${i} ? 'opacity-100' : 'opacity-30'`}
              class="w-2.5 h-2.5 rounded-full transition-opacity"
              style="background-color: #a75c4a;"
              aria-label={`Testimonial ${i + 1}`}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── OUR SERVICES: top-half white / bottom-half #a75c4a ── -->
  <section class="relative pt-14 pb-24">
    <!-- Bottom half fill -->
    <div class="absolute bottom-0 left-0 right-0 h-1/2" style="background-color: #a75c4a;"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-semibold text-center mb-14" style="color: #a75c4a;">
        Our Services
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
        {services.map(({ img, title, description, href }, i) => (
          <div class="flex flex-col items-center text-center bg-white rounded-xl p-6 shadow-sm">
            <!-- Circular image with 8px alternating border -->
            <div
              class="rounded-full overflow-hidden mb-5 flex-shrink-0"
              style={`width: 176px; height: 176px; border: 8px solid ${borderColors[i % 4]};`}
            >
              <img
                src={img}
                alt={title}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-semibold mb-3" style="color: #121111; font-size: 1.1rem;">{title}</h3>
            <p class="text-sm leading-relaxed mb-5 flex-1">{description}</p>
            <a
              href={href}
              class="text-[11px] font-semibold tracking-widest uppercase text-white px-6 py-2 rounded-full"
              style="background-color: #a75c4a;"
            >
              LEARN MORE
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CONTACT / LOCATIONS / HOURS ── -->
  <section style="background-color: #a75c4a;" class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-10 text-white">

        <div>
          <div class="flex items-center gap-3 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-sm font-bold tracking-widest uppercase">Contact Us</span>
          </div>
          <p class="text-sm text-white/90 mb-1">
            <a href="tel:9857730449" class="hover:text-white">(985) 773-0449</a>
          </p>
          <p class="text-sm text-white/90 mb-5">
            <a href="mailto:grace@midwifegrace.com" class="hover:text-white">grace@midwifegrace.com</a>
          </p>
          <a
            href="/contact"
            class="text-[11px] font-semibold tracking-widest uppercase border border-white/60 px-4 py-2 hover:bg-white/10 transition-colors inline-block"
          >
            Schedule a Consultation
          </a>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm font-bold tracking-widest uppercase">Locations</span>
          </div>
          <ul class="space-y-3 text-sm text-white/90">
            <li>340 Brakefield Street<br />Slidell, LA 70458</li>
            <li>407 Main Street<br />Madisonville, LA 70447</li>
            <li>223 N. Rendon<br />New Orleans, LA 70119</li>
          </ul>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-bold tracking-widest uppercase">Hours</span>
          </div>
          <ul class="space-y-1 text-sm text-white/90">
            {['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'].map(day => (
              <li class="flex justify-between gap-4">
                <span>{day}</span>
                <span>9:00 AM – 5:00 PM</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
