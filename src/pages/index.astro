---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SplitPanel from '../components/SplitPanel.astro';
import { Image } from 'astro:assets';

import bannerImg from '../assets/images/banner-1.png';
import homebirthTeamImg from '../assets/images/homebirth-team.jpeg';
import midwiferyImg from '../assets/images/midwifery.jpg';
import img0223 from '../assets/images/momma.jpg';
import doulaImg from '../assets/images/doula.jpeg';
import download1 from '../assets/images/download-1.jpg';
import placentaImg from '../assets/images/placenta.jpg';
import img6328 from '../assets/images/img6328.jpeg';
import flowers from '../assets/images/flowers-2.png';

const testimonials = [
  { quote: 'With her excellence in practice and delightful charm, I would welcome anyone to invite her into your story.', author: 'Rachel E' },
  { quote: 'I am so thankful for the midwives at Grace Midwifery Collective. I love how my son and daughters were included in my prenatal care, and having them at my birth was everything I had hoped for. The midwives answered their questions and made everyone feel safe and comfortable.', author: 'Cheri C' },
  { quote: 'I could never say enough good things about Grace & the practice she has put together. All of the women I come across in her birth studio are all so kind and loving. You can truly tell they all love their work.', author: 'Brittany T' },
  { quote: 'I wish every woman had the opportunity to experience the beauty of home birth with a team of women like Grace Midwifery Collective.', author: 'Luisa H' },
];
---

<BaseLayout
  title="Grace Midwifery Collective | Home Birth Midwifery in Louisiana & Mississippi"
  description="Evidence-based home birth midwifery care in Louisiana and Mississippi. Your birth. Your body. Your choice."
>
  <Nav />

  <!-- ── HERO: image only, 20px side margins, no text ── -->
  <div class="mx-5 mb-5">
    <Image
      src={bannerImg}
      alt="Grace Midwifery Collective"
      class="w-full block object-cover object-center"
      style="max-height: 70vh;"
    />
  </div>

  <!-- ── TRUST BAR ── -->
  <section class="py-5 text-white bg-brand-primary">
    <div class="w-full px-8">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-white/80">
        {['Licensed CPM, LM in Louisiana', '7+ Years of Home Births', 'Three Office Locations', '24/7 On-Call Support', 'Insurance Accepted'].map(item => (
          <span class="flex items-center gap-2">
            <span style="color: #DCB393;">✦</span> {item}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── OUR MISSION ── -->
  <section class="py-32 bg-white relative overflow-hidden">
    <Image
      src={flowers}
      alt=""
      aria-hidden="true"
      class="absolute -bottom-10 -right-10 w-96 pointer-events-none select-none"
      style="opacity: 0.2;"
    />
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <h6 class="justify-center">Welcome to Grace Midwifery Collective</h6>
      <h2 class="text-4xl md:text-5xl font-semibold mb-8 text-brand-primary">
        Our Mission
      </h2>
      <p class="leading-relaxed mb-6">
        We are on a mission to reshape the landscape of maternal health in Louisiana and Mississippi. We believe that when a mother is given <strong class="font-semibold" style="color: #121111;">evidence-based information</strong> and <strong class="font-semibold" style="color: #121111;">the autonomy</strong> to lead her own care, the entire family thrives. At Grace, your appointments aren't rushed—they are opportunities to build a relationship rooted in trust and respect.
      </p>
      <p class="font-semibold text-brand-primary">
        Your Birth. Your body. Your choice.
      </p>
      <p class="leading-relaxed">
        Join us in creating a legacy where every mother feels safe, heard, and powerful.
      </p>
    </div>
  </section>

  <!-- ── ABOUT GRACE ── -->

  <SplitPanel bg="#e5f2ef2b" image={homebirthTeamImg} imageAlt="Grace Midwifery team at a home birth">
    <h6>about me and my vision</h6>
    <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-8 text-brand-primary">
      Grace Jackson CPM, LM
    </h2>
    <p class="leading-relaxed mb-5">
      Grace Jackson is a Certified Professional Midwife licensed in the state of Louisiana, with over seven years of experience attending home births. Grace provides compassionate, evidence informed midwifery care centered on safety, autonomy and connection.
    </p>
    <p class="leading-relaxed">
      As the founder of Grace Midwifery Collective, Grace is dedicated to igniting a revolution in birth care. The collective brings together a vibrant community of midwives, doulas, childbirth educators, lactation consultants and placenta encapsulation all under one umbrella to offer holistic, respectful and vetted care for every stage of women's health with ease.
    </p>
  </SplitPanel>

  <!-- ── SERVING YOUR COMMUNITY + MAP + TESTIMONIALS ── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6 text-brand-primary">
        Serving Your Community
      </h2>
      <p class="leading-relaxed max-w-2xl mx-auto mb-12">
        Midwife Grace serves many communities within southeast Louisiana and southwest Mississippi. We offer home birth within a <strong class="font-semibold" style="color: #121111;">1hr and 10 min radius</strong> of Madisonville. Offering prenatal care conveniently located to your home, with offices in Madisonville, Slidell and New Orleans.
      </p>

      <!-- Map -->
      <div class="w-full mb-14 rounded-lg overflow-hidden bg-gray-100" style="height: 300px;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110305.22!2d-90.15!3d30.42!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8620b34f!2sMadisonville%2C+LA!5e0!3m2!1sen!2sus!4v1234567890"
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Grace Midwifery service area"
        ></iframe>
      </div>


    </div>
  </section>

  <!-- ── SERVICES ── -->
  <section class="py-24 lg:py-32 relative overflow-hidden" style="background-color: #e5f2ef2b;">

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 mb-4 justify-center">
          <h6>What We Offer</h6>
        </div>
        <h2 class="text-3xl md:text-4xl font-semibold mb-6 text-brand-primary">
          Comprehensive care for every stage of your journey
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            img: midwiferyImg,
            title: 'Midwifery Care',
            description: 'The Midwifery model of care is built on the understanding that pregnancy and birth are normal life events, not medical emergencies. Care is individualized and centered on informed choice, safety and trust.',
            href: '/midwifery-care',
          },
          {
            img: img0223,
            title: 'Lactation',
            description: 'Lactation assistance is included in our midwifery package. An International Board Certified Lactation Counselor visits your home at the 3 day visit to assist with a successful start to your breast feeding journey.',
            href: '/doula-support',
          },
          {
            img: doulaImg,
            title: 'Doula Support',
            description: 'Doulas are an integral part of birth support. We are excited to announce a special opportunity to offer doulas as part of the Grace Midwifery Collective.',
            href: '/doula-support',
          },
          {
            img: download1,
            title: 'Childbirth Education',
            description: 'Preparing for birth through education is an important part of your parenting journey. Comprehensive and evidence-based classes offered several times per year.',
            href: '/education',
          },
          {
            img: placentaImg,
            title: 'Placenta Encapsulation',
            description: 'Placenta encapsulation is a traditional postpartum practice chosen by some families to support recovery after birth. Many parents report benefits such as; improved energy, mood support, and a gentler postpartum transition. For this service text 985-773-0449',
            href: '/contact',
          },
          {
            img: img6328,
            title: 'Postpartum Care',
            description: 'In-home postpartum care provides quiet, attentive support in the comfort of your home. Scheduled visit check your recovery, weigh and assess your baby, support feeding and offer gentle, holistic guidance. Available for mothers and their newborn regardless of where you birthed.',
            href: '/contact',
          },
        ].map(({ img, title, description, href }, i) => (
            <div
                x-data="{ visible: false }"
                x-intersect.once="visible = true"
                :class="visible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'"
                class="transition-all duration-700 ease-out"
                style={`transition-delay: ${i * 100}ms`}
            >
              <a href={href} class="group block bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-shadow duration-300 h-full">
                <div class="overflow-hidden h-48">
                  <Image
                    src={img}
                    alt={title}
                    width={600}
                    height={400}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
                <div class="p-6">
                  <h3 class="font-serif text-xl text-sage-900 mb-3">{title}</h3>
                  <p class="text-sm text-warm-500 leading-relaxed mb-4">{description}</p>
                  <span class="inline-flex items-center gap-1 text-sm text-brand-primary font-medium group-hover:gap-2 transition-all">
                  Learn more
                  <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
                </div>
              </a>
            </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="py-24" style="background-color: #fff;">
    <div class="w-full px-8">
      <div class="text-center mb-16">
        <h6 class="justify-center mb-4">In Their Own Words</h6>
        <h2 class="text-4xl text-brand-primary lg:text-5xl font-semibold">Stories From Our Families</h2>
      </div>

      <div x-data={`{ active: 0, count: ${testimonials.length} }`} class="max-w-3xl mx-auto">

        <!-- All cards stacked in the same grid cell — height locks to tallest -->
        <div class="grid">
          {testimonials.map(({ quote, author }, i) => (
            <figure
              style="background-color: #fef4f3;"
              class="[grid-area:1/1] rounded-2xl p-10 shadow-sm flex flex-col items-center justify-center text-center transition-opacity duration-500"
              :class={`active === ${i} ? 'opacity-100' : 'opacity-0 pointer-events-none'`}
            >
              <blockquote class="mb-6" style="color: #121111; font-size: 1.5rem; line-height: 1.6;">
                "{quote}"
              </blockquote>
              <figcaption class="font-semibold text-brand-primary">— {author}</figcaption>
            </figure>
          ))}
        </div>

        <!-- Prev · dots · Next -->
        <div class="flex items-center justify-center gap-4 mt-8">
          <button
            @click="active = (active - 1 + count) % count"
            class="w-8 h-8 rounded-full border flex items-center justify-center transition-colors hover:bg-brand-primary hover:text-white"
            style="border-color: #DCB393; color: #DCB393;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

          <div class="flex items-center gap-2">
            {testimonials.map((_, i) => (
              <button
                @click={`active = ${i}`}
                class="h-2 rounded-full transition-all duration-300"
                :style={`active === ${i} ? 'background-color:#a75c4a;width:1.5rem' : 'background-color:#DCB393;width:0.5rem'`}
              />
            ))}
          </div>

          <button
            @click="active = (active + 1) % count"
            class="w-8 h-8 rounded-full border flex items-center justify-center transition-colors hover:bg-brand-primary hover:text-white"
            style="border-color: #DCB393; color: #DCB393;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
